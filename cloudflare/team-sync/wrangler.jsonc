{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "core-research-team-sync",
  "main": "worker.js",
  "compatibility_date": "2026-07-08",
  "workers_dev": true,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "kv_namespaces": [
    {
      "binding": "TEAM_CHAT_KV",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID"
    }
  ]
}
